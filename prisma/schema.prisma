generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum MemberStatus {
  ACTIVE
  REMOVED
  LEFT
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  REVOKED
}

enum TripStatus {
  DRAFT
  PLANNING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum StopStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum StayStatus {
  OPTION
  BOOKED
  CANCELLED
}

enum ActivityStatus {
  IDEA
  OPTION
  PLANNED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum SupplyItemStatus {
  NEEDED
  PARTIALLY_COVERED
  COVERED
  NOT_NEEDED
}

enum ExpenseSplitMode {
  EQUAL
  WEIGHTED
  CUSTOM
}

enum ExpenseStatus {
  PENDING
  SETTLED
  DISPUTED
  CANCELLED
}

enum VoteTopicType {
  DATES
  DESTINATION
  ACTIVITY
  BUDGET
  ACCOMMODATION
  OTHER
}

enum VoteOptionType {
  YES_NO
  MULTIPLE_CHOICE
}

enum VoteStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum CommentableType {
  TRIP
  STOP
  STAY
  ACTIVITY
  EXPENSE
  SUPPLY_ITEM
  VOTE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id         String    @id @default(cuid())
  externalId String?   @unique
  email      String    @unique
  name       String
  avatarUrl  String?
  timezone   String    @default("UTC")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  memberships        TripMember[]
  sentInvites        TripInvite[]  @relation("InviteSender")
  receivedInvites    TripInvite[]  @relation("InviteRecipient")
  activitiesCreated  Activity[]    @relation("ActivityCreator")
  expensesPaid       Expense[]     @relation("ExpensePayer")
  expensesCreated    Expense[]     @relation("ExpenseCreator")
  expenseShares      ExpenseShare[]
  supplyItemsBrought SupplyItem[]  @relation("SupplyBringer")
  supplyItemsBought  SupplyItem[]  @relation("SupplyBuyer")
  supplyItemsCreated SupplyItem[]  @relation("SupplyCreator")
  voteResponses      VoteResponse[]
  comments           Comment[]
  staysCreated       Stay[]

  @@index([email])
  @@index([externalId])
  @@map("users")
}

model Trip {
  id            String     @id @default(cuid())
  name          String
  description   String?
  coverImageUrl String?
  status        TripStatus @default(PLANNING)
  currency      String     @default("USD")
  budgetTarget  Decimal?   @db.Decimal(12, 2)
  estimatedCostOverride Decimal? @db.Decimal(12, 2)
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  members     TripMember[]
  invites     TripInvite[]
  stops       Stop[]
  expenses    Expense[]
  supplyItems SupplyItem[]
  votes       Vote[]
  comments    Comment[]

  @@index([status])
  @@index([startDate])
  @@map("trips")
}

model TripMember {
  id        String       @id @default(cuid())
  tripId    String
  userId    String
  role      MemberRole   @default(MEMBER)
  status    MemberStatus @default(ACTIVE)
  joinedAt  DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([tripId])
  @@index([userId])
  @@map("trip_members")
}

model TripInvite {
  id          String       @id @default(cuid())
  tripId      String
  senderId    String
  recipientId String?
  email       String?
  token       String       @unique @default(cuid())
  role        MemberRole   @default(MEMBER)
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  trip      Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  sender    User  @relation("InviteSender", fields: [senderId], references: [id])
  recipient User? @relation("InviteRecipient", fields: [recipientId], references: [id])

  @@index([tripId])
  @@index([token])
  @@index([email])
  @@map("trip_invites")
}

model Stop {
  id            String     @id @default(cuid())
  tripId        String
  name          String
  country       String?
  description   String?
  latitude      Decimal?   @db.Decimal(9, 6)
  longitude     Decimal?   @db.Decimal(9, 6)
  placeId       String?
  sortOrder     Int
  arrivalDate   DateTime?
  departureDate DateTime?
  status        StopStatus @default(DRAFT)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stays      Stay[]
  activities Activity[]
  comments   Comment[]

  @@index([tripId, sortOrder])
  @@map("stops")
}

model Stay {
  id             String     @id @default(cuid())
  stopId         String
  createdById    String
  name           String
  address        String?
  url            String?
  confirmationNo String?
  roomSiteNumbers String[]
  arrivalTime    String?
  checkIn        DateTime?
  checkInTime    String?
  checkOut       DateTime?
  checkOutTime   String?
  leaveTime      String?
  pricePerNight  Decimal?   @db.Decimal(10, 2)
  totalPrice     Decimal?   @db.Decimal(10, 2)
  currency       String?
  status         StayStatus @default(OPTION)
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  stop      Stop @relation(fields: [stopId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id])

  @@index([stopId])
  @@map("stays")
}

model Activity {
  id            String         @id @default(cuid())
  stopId        String
  createdById   String
  name          String
  description   String?
  url           String?
  address       String?
  scheduledDate DateTime?
  startTime     String?
  endTime       String?
  durationMins  Int?
  estimatedCost Decimal?       @db.Decimal(10, 2)
  actualCost    Decimal?       @db.Decimal(10, 2)
  status        ActivityStatus @default(IDEA)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  stop      Stop      @relation(fields: [stopId], references: [id], onDelete: Cascade)
  createdBy User      @relation("ActivityCreator", fields: [createdById], references: [id])
  comments  Comment[]

  @@index([stopId, scheduledDate])
  @@index([stopId, sortOrder])
  @@map("activities")
}

model SupplyItem {
  id                String           @id @default(cuid())
  tripId            String
  createdById       String
  whoBringsId       String?
  whoBoughtId       String?
  name              String
  description       String?
  category          String?
  quantityNeeded    Int              @default(1)
  quantityOwned     Int              @default(0)
  quantityRemaining Int              @default(1)
  estimatedCost     Decimal?         @db.Decimal(10, 2)
  actualCost        Decimal?         @db.Decimal(10, 2)
  status            SupplyItemStatus @default(NEEDED)
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  trip      Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy User        @relation("SupplyCreator", fields: [createdById], references: [id])
  whoBrings User?       @relation("SupplyBringer", fields: [whoBringsId], references: [id])
  whoBought User?       @relation("SupplyBuyer", fields: [whoBoughtId], references: [id])
  comments  Comment[]

  @@index([tripId])
  @@index([tripId, status])
  @@map("supply_items")
}

model Expense {
  id          String           @id @default(cuid())
  tripId      String
  paidById    String
  createdById String
  title       String
  description String?
  category    String?
  totalAmount Decimal          @db.Decimal(12, 2)
  currency    String           @default("USD")
  splitMode   ExpenseSplitMode @default(EQUAL)
  receiptUrl  String?
  expenseDate DateTime         @default(now())
  status      ExpenseStatus    @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  trip      Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  paidBy    User           @relation("ExpensePayer", fields: [paidById], references: [id])
  createdBy User           @relation("ExpenseCreator", fields: [createdById], references: [id])
  shares    ExpenseShare[]
  comments  Comment[]

  @@index([tripId])
  @@index([tripId, status])
  @@index([paidById])
  @@map("expenses")
}

model ExpenseShare {
  id           String    @id @default(cuid())
  expenseId    String
  userId       String
  weight       Decimal?  @db.Decimal(8, 4)
  customAmount Decimal?  @db.Decimal(12, 2)
  hasPaid      Boolean   @default(false)
  paidAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@index([expenseId])
  @@index([userId])
  @@map("expense_shares")
}

model Vote {
  id            String         @id @default(cuid())
  tripId        String
  createdById   String?
  title         String
  description   String?
  topicType     VoteTopicType
  optionType    VoteOptionType @default(MULTIPLE_CHOICE)
  allowMultiple Boolean        @default(false)
  isAnonymous   Boolean        @default(false)
  deadline      DateTime?
  status        VoteStatus     @default(OPEN)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  closedAt      DateTime?

  trip      Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  options   VoteOption[]
  responses VoteResponse[]
  comments  Comment[]

  @@index([tripId])
  @@index([tripId, status])
  @@map("votes")
}

model VoteOption {
  id        String   @id @default(cuid())
  voteId    String
  label     String
  dateStart DateTime?
  dateEnd   DateTime?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  vote      Vote           @relation(fields: [voteId], references: [id], onDelete: Cascade)
  responses VoteResponse[]

  @@index([voteId])
  @@map("vote_options")
}

model VoteResponse {
  id           String   @id @default(cuid())
  voteId       String
  voteOptionId String
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vote       Vote       @relation(fields: [voteId], references: [id], onDelete: Cascade)
  voteOption VoteOption @relation(fields: [voteOptionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@unique([voteId, voteOptionId, userId])
  @@index([voteId])
  @@index([userId])
  @@map("vote_responses")
}

model Comment {
  id             String          @id @default(cuid())
  authorId       String
  entityType     CommentableType
  entityId       String
  tripId         String?
  stopId         String?
  activityId     String?
  expenseId      String?
  supplyItemId   String?
  voteId         String?
  threadParentId String?
  body           String
  editedAt       DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  author     User        @relation(fields: [authorId], references: [id])
  trip       Trip?       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stop       Stop?       @relation(fields: [stopId], references: [id], onDelete: Cascade)
  activity   Activity?   @relation(fields: [activityId], references: [id], onDelete: Cascade)
  expense    Expense?    @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  supplyItem SupplyItem? @relation(fields: [supplyItemId], references: [id], onDelete: Cascade)
  vote       Vote?       @relation(fields: [voteId], references: [id], onDelete: Cascade)

  threadParent Comment?  @relation("CommentThread", fields: [threadParentId], references: [id])
  replies      Comment[] @relation("CommentThread")

  @@index([entityType, entityId])
  @@index([authorId])
  @@index([threadParentId])
  @@map("comments")
}

model AuditLog {
  id           String   @id @default(cuid())
  action       String
  actorUserId  String?
  tripId       String?
  targetUserId String?
  targetId     String?
  summary      String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([tripId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

/// Short-lived server-side undo payload (consumer must match actorUserId).
model UndoToken {
  id          String    @id @default(cuid())
  actorUserId String
  tripId      String
  kind        String
  payload     Json
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([actorUserId, tripId])
  @@index([expiresAt])
  @@map("undo_tokens")
}

model AppErrorLog {
  id        String   @id @default(cuid())
  source    String
  message   String
  stack     String?
  userId    String?
  tripId    String?
  context   Json?
  createdAt DateTime @default(now())

  @@index([source, createdAt])
  @@index([tripId, createdAt])
  @@index([userId, createdAt])
  @@map("app_error_logs")
}

model RateLimitEvent {
  id         String   @id @default(cuid())
  scope      String
  identifier String
  key        String?
  createdAt  DateTime @default(now())

  @@index([scope, identifier, createdAt])
  @@index([createdAt])
  @@map("rate_limit_events")
}
