# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase pooler — copy host/user from Dashboard → Database → Connection string)
# Transaction pooler (6543) + Session/direct via pooler (5432); replace [YOUR-PASSWORD]
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# App
# Local: http://localhost:3000. On Vercel, set to your real site URL (e.g. https://beacontravel.vercel.app)
# or omit NEXT_PUBLIC_APP_URL so the deployment URL is used — never set this to localhost in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false

# Optional: Resend (https://resend.com) — invite emails. Without RESEND_API_KEY and EMAIL_FROM,
# invites still work: the app creates a TripInvite and shows a copyable link in the dialog.
RESEND_API_KEY=
# Display name and sender address verified in Resend, e.g. "Beacon <invites@yourdomain.com>"
EMAIL_FROM=

# Optional: Supabase Storage — public bucket `trip-covers` for trip card cover uploads
# (Dashboard → Storage → create `trip-covers` → set Public. One cover URL is stored on the trip row; every member loads that same URL, so the bucket must allow public GET. Policies: authenticated users can upload/update/delete their objects under `/{userId}/{tripId}/…`.)
